[Unit]
Description=Pull Ollama embedding model
After=ollama.service
Requires=ollama.service

[Service]
Type=oneshot
ExecStartPre=/bin/sh -c 'until curl -sf http://127.0.0.1:11434/; do sleep 1; done; /bin/mkdir -p /opt/models'
ExecStart=/usr/local/bin/ollama pull nomic-embed-text
Environment=OLLAMA_HOST=0.0.0.0:11434
Environment=OLLAMA_MODELS=/opt/models
TimeoutStartSec=300
RemainAfterExit=yes

[Install]
WantedBy=default.target
