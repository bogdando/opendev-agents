[Unit]
Description=OpenViking memory server (local mode)
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
ExecStart=%h/.pyenv/versions/3.12.12/bin/openviking-server --config %h/.openviking/ov.conf
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1
Environment=NO_PROXY=127.0.0.1,localhost,::1

[Install]
WantedBy=default.target
