{
  "mcpServers": {
    "rag-knowledge": {
      "command": "rag-mcp-server",
      "env": {
        "RAG_MCP_BACKEND": "mock",
        "RAG_MCP_KNOWLEDGE_DIR": "/opt/go/src/github.com/bogdando/opendev-agents/knowledge"
      }
    },
    "rag-knowledge-wiki": {
      "command": "rag-mcp-server",
      "env": {
        "RAG_MCP_BACKEND": "confluence",
        "RAG_MCP_CONFLUENCE_URL": "${CONFLUENCEURL}",
        "RAG_MCP_CONFLUENCE_EMAIL": "${CONFLUENCEEMAIL}",
        "RAG_MCP_CONFLUENCE_TOKEN": "${CONFLUENCETOKEN}",
        "RAG_MCP_CONFLUENCE_SPACE": "${CONFLUENCESPACE}"
      }
    },
    "rag-knowledge-okp": {
      "command": "rag-mcp-server",
      "env": {
        "RAG_MCP_BACKEND": "solr",
        "RAG_MCP_SOLR_URL": "${OKPSOLRURL}",
        "SSL_CERT_FILE": "/etc/pki/tls/certs/ca-bundle.crt",
        "SSL_CERT_FILE_ALT": "${OKPSSLCERTFILE}",
        "NO_PROXY": "${OKPNOPROXY}",
        "no_proxy": "${OKPNOPROXY}"
      }
    }
  }
}
